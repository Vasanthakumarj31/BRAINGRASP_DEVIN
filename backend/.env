# ============================================================
# BrainyGrasp Backend — Environment Variables
# NEVER commit this file to Git. Add .env to .gitignore.
# ============================================================

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_USER=vasanthvasanth4863@gmail.com
EMAIL_PASS=gcgnxvyuvgjelepx

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=abfa7c2720abd2c46c1a7354883518e05a89fea72d26a74d7e2fafcb1d5e7d7a766d5531a855eae3879a782b15e32c5fcfc2565843e9cdaab93add7436c9d5dd

# ── PostgreSQL ───────────────────────────────────────────────
# LOCAL (Docker):
DB_USER=postgres
DB_HOST=localhost
DB_NAME=brainygras
DB_PASSWORD=password
DB_PORT=5432
# PRODUCTION (Neon/Supabase): comment out the above and use:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Redis ────────────────────────────────────────────────────
# LOCAL (Docker):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
# PRODUCTION (Upstash): comment out above and use:
# REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@your-upstash-url:6379

# ── Environment ───────────────────────────────────────────────
# Set to 'production' on Render/Railway to disable verbose logs
NODE_ENV=development

# ── Server Port ───────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────
# LOCAL: leave blank (allows all origins with *)
# PRODUCTION: comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.brainygrasp.com
ALLOWED_ORIGINS=

# ── Razorpay ─────────────────────────────────────────────────
# TEST keys: prefix rzp_test_ (safe for development)
# LIVE keys: prefix rzp_live_ (use ONLY after Razorpay approval)
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET

# ── Admin Panel ───────────────────────────────────────────────
# Change these before going to production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123