# ── Environment ───────────────────────────────────────────────
# Set to 'production' on Render/Railway to disable verbose logs
NODE_ENV=development

# ── Server Port ───────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────
# LOCAL: leave blank (allows all origins with *)
# PRODUCTION: comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.brainygrasp.com
ALLOWED_ORIGINS=

# ── Razorpay ─────────────────────────────────────────────────
# TEST keys: prefix rzp_test_ (safe for development)
# LIVE keys: prefix rzp_live_ (use ONLY after Razorpay approval)
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET

# ── Admin Panel ───────────────────────────────────────────────
# Change these before going to production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123