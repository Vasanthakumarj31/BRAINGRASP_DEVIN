# ============================================================
# BrainyGrasp — PRODUCTION Environment Variables Template
# Copy this as .env and fill in your real values.
# NEVER commit .env to Git.
# ============================================================

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# ── PostgreSQL (choose ONE block) ────────────────────────────

# OPTION A — Cloud (Neon / Supabase / Railway):
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OPTION B — Local Docker (comment out DATABASE_URL above):
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=brainygras
# DB_PASSWORD=your_password
# DB_PORT=5432

# ── Redis (choose ONE block) ─────────────────────────────────

# OPTION A — Cloud (Upstash):
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@your-url.upstash.io:6379

# OPTION B — Local Docker (comment out REDIS_URL above):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ── Environment ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of your Vercel frontend URL(s)
ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.brainygrasp.com

# ── Razorpay ─────────────────────────────────────────────────
# Use rzp_test_ keys for testing, rzp_live_ after approval
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET

# ── Admin Panel ───────────────────────────────────────────────
# Change these from defaults before production!
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_admin_password