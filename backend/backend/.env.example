# BrainyGrasp Backend Environment Configuration
# Copy this file to .env and update with your values

# ── Database Configuration ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brainygras

# ── Redis Configuration (Caching) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ── JWT Configuration ──────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=super_secret_brainygrasp_key_CHANGE_ME_IN_PRODUCTION

# ── Email Configuration (OTP Delivery) ──────────────────────────────────────
# Gmail SMTP credentials required for sending OTPs
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ── Razorpay Payment Gateway ────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Server Configuration ────────────────────────────────────────────────────
PORT=3000

# ── CORS Configuration (Optional) ────────────────────────────────────────────
# Leave empty to allow all origins, or specify comma-separated list
# ALLOWED_ORIGINS=http://localhost:5500,https://yourdomain.com

# ── pgAdmin Configuration ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
